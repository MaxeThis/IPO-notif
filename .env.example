# ── Email (required) ───────────────────────────────────────────────────────────
# Gmail: generate an App Password at myaccount.google.com/apppasswords
# (requires 2FA enabled on your Google account)
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_RECIPIENT=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Optional: NewsAPI (newsapi.org) for broader news coverage ──────────────────
# Free tier: 100 requests/day. Leave blank to use Google News RSS only.
NEWS_API_KEY=

# ── Check intervals (minutes) ─────────────────────────────────────────────────
SEC_CHECK_INTERVAL=360
NEWS_CHECK_INTERVAL=60
HOLDINGS_CHECK_INTERVAL=30
